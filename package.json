{
  "name": "gcp-authcalator",
  "version": "0.9.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "start": "bun run index.ts",
    "test": "bun test",
    "typecheck": "bun run tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun run lint && bun run format:check",
    "build": "bun run scripts/build.ts",
    "build:linux-amd64": "bun run scripts/build.ts --target=bun-linux-x64 --outfile=gcp-authcalator-linux-amd64",
    "build:linux-arm64": "bun run scripts/build.ts --target=bun-linux-arm64 --outfile=gcp-authcalator-linux-arm64",
    "build:darwin-arm64": "bun run scripts/build.ts --target=bun-darwin-arm64 --outfile=gcp-authcalator-darwin-arm64",
    "release": "bun run scripts/release.ts",
    "prepare": "prek install"
  },
  "dependencies": {
    "@peculiar/x509": "^2.0.0",
    "google-auth-library": "^10.6.2",
    "reflect-metadata": "^0.2.2",
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
